* {
    border: none;
    font-family: "Ubuntu Nerd Font", sans-serif;
    font-size: 13px;
    font-weight: 500;
}

window#waybar { background: transparent; }

/* ОБЩИЙ СТИЛЬ БЛОКОВ */
#custom-launcher, #custom-chrome, #custom-github, #custom-terminal,
#pulseaudio, #network, #clock, #workspaces {
    background: rgba(17, 19, 23, 0.9);
    margin: 5px 3px;
    border-radius: 10px;
    border: 1px solid rgba(137, 220, 235, 0.05); /* Едва заметная рамка */
}

/* ФИКСИРОВАННАЯ ШИРИНА ДЛЯ СИММЕТРИИ */
#custom-launcher, #custom-chrome, #custom-github, #custom-terminal {
    min-width: 44px; 
    padding: 5px 0px;
}

/* ЦВЕТОКОРРЕКЦИЯ ИКОНОК */
#custom-launcher { 
    font-size: 16px; 
    color: #cba6f7; /* Мягкий фиолетовый (Mauve) */
    margin-left: 15px; 
}

#custom-chrome, #custom-github, #custom-terminal { 
    font-size: 16px; 
    color: #74c7ec; /* Единый голубой цвет (Sapphire) для всех приложений */
}

/* ЦЕНТР (Воркспейсы) */
#workspaces button { 
    color: rgba(137, 220, 235, 0.3); /* Тусклый голубой для неактивных */
    padding: 0 8px; 
}
#workspaces button.active { 
    color: #89dceb; /* Яркий голубой (Sky) */
    background: rgba(137, 220, 235, 0.15); 
    border-radius: 8px; 
}

/* ПРАВАЯ ПАНЕЛЬ (Системные цвета) */
#pulseaudio { color: #89dceb; padding: 0 12px; }
#network    { color: #abe9b3; padding: 0 12px; } /* Нежно-зеленый для сети */
#clock      { color: #cba6f7; padding: 0 15px; margin-right: 15px; } /* Фиолетовый в тон лаунчеру */

/* ЭФФЕКТ ПРИ НАВЕДЕНИИ */
#custom-chrome:hover, #custom-github:hover, #custom-terminal:hover {
    background: rgba(116, 199, 236, 0.1);
    color: #ffffff;
}

